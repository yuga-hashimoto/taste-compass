# 好みズレ診断 (Taste Compass) - 環境変数テンプレート
# 開発時および本番デプロイ時は、このファイルをコピーして `.env` または `.env.local` を作成してください。

# 1. Supabase 接続情報 (必須)
# ※ クライアントサイド (Expo) から安全に参照するため、EXPO_PUBLIC_ プレフィックスを付与しています。
# ※ 管理者用の service_role キーなどの特権キーは絶対に設定しないでください。
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 2. 広告表示制御 (任意)
# true に設定すると、AdSlot.tsx にて抽象化された広告表示コンポーネントが有効化されます。
# false の場合はプレースホルダー表示または非表示になります。
EXPO_PUBLIC_ENABLE_ADS=false
